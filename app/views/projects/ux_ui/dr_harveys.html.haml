:javascript
    function initSwiper() {
        var swiperEl = document.querySelector('.personasSwiper')
        if (!swiperEl) return
        if (swiperEl.swiper) return
        requestAnimationFrame(function() {
            new Swiper('.personasSwiper', {
                slidesPerView: 1.5,
                centeredSlides: true,
                spaceBetween: 30,
                allowTouchMove: true,
                loop: true,
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                observer: true,
                observeParents: true,
            })
        })
    }
    document.addEventListener('turbo:load', initSwiper)
    initSwiper()