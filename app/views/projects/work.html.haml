.projects-page__wrapper
    .container
        %h1.projects__title Projects
        .filter
            .columns.is-variable.is-1.is-mobile.is-multiline
                .column.is-narrow
                    %p.filter__button#filter__button-all
                        All
                .column.is-narrow
                    %p.filter__button#filter__button-uxui
                        Product Design
                .column.is-narrow
                    %p.filter__button#filter__button-graphic
                        Graphic Design
        .columns.is-multiline.is-variable.is-4.filtered-columns
            .column.is-4-desktop.is-6-tablet{ data: { category: "uxui" } }
                = link_to "/ux-ui/island-finance-web", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/islandfinance-preview.webp', width: 800, height: 600, alt: 'Island Finance Case Study'
                        .projects__arrow.blue
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h2 Island Finance
                        %p.projects__project-description
                            A website redesign for Puerto Rico's go-to personal loan provider, built around clarity, trust, and financial accessibility.
                .tags__wrapper
                    .tags__project-tag
                        UX Research
                    .tags__project-tag
                        Product Design
                    
            .column.is-4-desktop.is-6-tablet{ data: { category: "uxui" } }
                = link_to "/ux-ui/dr-harveys", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/drharveys-preview.webp', width: 800, height: 600, alt: 'Dr.Harveys Case Study'
                        .projects__arrow.pink
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h2 Dr. Harvey's
                        %p.projects__project-description
                            How a cleaner, more intentional web presence helped Dr. Harvey's communicate trust, transparency, and wholesome care.
                .tags__wrapper
                    .tags__project-tag
                        Product Design
                    .tags__project-tag
                        User Testing
            .column.is-4-desktop.is-6-tablet.column.is-4-desktop.is-6-tablet{ data: { category: "graphic" } }
                = link_to "/graphic-design/ocean-spray", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/oceanspray-preview.webp', width: 800, height: 600, alt: 'Ocean Spray'
                        .projects__arrow.red
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h2 Ocean Spray
                        %p.projects__project-description
                            Marketing campaign for Ocean Spray designed to introduce the brand to health-conscious consumers and promote its wholesome benefits. 
                .tags__wrapper
                    .tags__project-tag
                        Marketing
                    .tags__project-tag
                        POP
                    .tags__project-tag
                        Social Media
                    
            .column.is-4-desktop.is-6-tablet.column.is-4-desktop.is-6-tablet{ data: { category: "graphic" } }
                = link_to "/graphic-design/cause-x-effect", :class => "project-button" do
