.hero__wrapper
    .container
        .hero__text
            .h2
                .columns.is-variable.is-gapless.is-multiline
                    .column.is-narrow-desktop.is-12-touch.hero__wave-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/wave.svg', alt: 'wave', class: 'wave-wrapper__wave-img'
                    .column.is-narrow-desktop.is-12-touch.hero__small-text
                        %p Hi, my name is Nicole Salazar and I'm a...
            %h1.hero__big-text
                #hero__variable-text
                %span
                    Designer &
                %br
                    Front End Developer

.projects__wrapper
    .container
        %h3 Projects
        .columns.is-variable.is-5
            .column.is-4-desktop.is-6-tablet
                = link_to "/ux-ui/island-finance-web", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/ifpreview.png', alt: 'Island Finance Case Study', loading: 'lazy'
                        .projects__arrow.blue
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h4 Island Finance
                        %p.projects__project-description
                            A website redesign for Puerto Rico's go-to personal loan provider, built around clarity, trust, and financial accessibility. 
            .column.is-4-desktop.is-6-tablet
                = link_to "/ux-ui/dr-harveys", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/drhpreview.png', alt: 'Dr.Harveys Case Study', loading: 'lazy'
                        .projects__arrow.pink
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h4 Dr. Harvey's
                        %p.projects__project-description
                            How a cleaner, more intentional web presence helped Dr. Harvey's communicate trust, transparency, and wholesome care.
            .column.is-4-desktop.is-hidden-tablet-only	
                = link_to "/graphic-design/ocean-spray", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/oceanspraypreview.png', alt: 'Ocean Spray', loading: 'lazy'
                        .projects__arrow.red
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h4 Ocean Spray
                        %p.projects__project-description
                            Marketing campaign for Ocean Spray designed to introduce the brand to health-conscious consumers and promote its wholesome benefits.
        .btn__wrapper
            = link_to "View All Projects", "/ux-ui", :class => "btn"


