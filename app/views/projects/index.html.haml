.projects__wrapper
    .container
        %h2.projects__title Projects
        .columns.is-variable.is-4
            .column.is-4-desktop.is-6-tablet
                = link_to "/ux-ui/island-finance-web", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/islandfinance-preview.webp', width: 800, height: 800, alt: 'Island Finance Case Study', loading: 'lazy'
                        .projects__arrow.blue
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h3 Island Finance
                        %p.projects__project-description
                            A website redesign for Puerto Rico's go-to personal loan provider, built around clarity, trust, and financial accessibility. 
            .column.is-4-desktop.is-6-tablet
                = link_to "/ux-ui/dr-harveys", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/drharveys-preview.webp', width: 800, height: 800, alt: 'Dr.Harveys Case Study', loading: 'lazy'
                        .projects__arrow.pink
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h3 Dr. Harvey's
                        %p.projects__project-description
                            How a cleaner, more intentional web presence helped Dr. Harvey's communicate trust, transparency, and wholesome care.
            .column.is-4-desktop.is-hidden-tablet-only	
                = link_to "/graphic-design/ocean-spray", :class => "project-button" do
                    .projects__cover-wrapper
                        = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/oceanspray-preview.webp', width: 800, height: 800, alt: 'Ocean Spray', loading: 'lazy'
                        .projects__arrow.red
                            = inline_svg('arrow.svg')
                    .project__project-summary
                        %h3 Ocean Spray
                        %p.projects__project-description
                            Marketing campaign for Ocean Spray designed to introduce the brand to health-conscious consumers and promote its wholesome benefits.
        .btn__wrapper
            = link_to "View All Projects", "/work", :class => "btn"
.about-home__wrapper
    .container
        .about-home__title-wrapper
            %h2.about__title About Me 
        .columns.is-variable.is-4-desktop.is-multiline
            .column.is-6-desktop.is-12-tablet.is-hidden-touch
                .about-home__img-wrapper
                    = image_tag 'https://nicolada-website.s3.us-east-1.amazonaws.com/Nicole-Salazar-Img.webp', width: 1080, height: 1440, alt: 'Nicole Salazar Portrait', loading: 'lazy'
            .column.is-6-desktop.is-12-tablet
                .about-home__text-wrapper
                    %h3.about__highlight
                        I'm Nicole, a designer and front end developer from Dominican Republic, based in New Jersey.
                    %p
                        I specialize in Graphic and UX/UI Design and Front End Development. In over 6 years I've worked with a range of clients across wellness, finance, tech, and entertainment. Because I understand both sides of the process, I create work that is as thoughtful as it is functional. I bring a meticulous eye, a love for experimentation, and a commitment to creating work that is engaging, and leaves a lasting impression. 
                    .btn__wrapper
                        = link_to "Get to Know Me", "/about", :class => "btn"
