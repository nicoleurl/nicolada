<!DOCTYPE html>
<html lang="en" data-theme="light" data-color-scheme="light">
  <head>
    <title><%= content_for(:title) || "Nicolada" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light only">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#fff9ef">
    <meta name="description" content="<%= content_for(:description) || 'Nicole Salazar is a Product Designer and Art Director with 7+ years of experience in UX/UI design, graphic design, and art direction.' %>">
    <meta property="og:image" content="nicolada-meta-img.png"/>
    <meta property="og:description" content="<%= content_for(:og_description) || content_for(:description) || 'Nicole Salazar is a Product Designer and Art Director with 7+ years of experience. Explore her portfolio of digital and visual work.' %>">
    <meta property="og:url" content="<%= request.original_url %>"/>
    <meta property="og:image:width" content="1200"/>
    <meta property="og:image:height" content="628"/>
    <%= favicon_link_tag 'favicon-bw.ico' %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if @load_swiper %>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>
      <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" data-turbo-track="reload"></script>
    <% end %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css"></noscript>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" as="style" onload="this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"></noscript>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" as="style" onload="this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"></noscript>
    <link rel="stylesheet" href="https://use.typekit.net/dco6nqj.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="<%= content_for(:body_class) %>">
    <header>
      <div class="navbar">
        <div class="navbar-brand">
          <%= link_to "/", aria: { label: "Nicolada - Home" } do %>
            <%= image_tag asset_path("nicolada-logomark.svg"), alt: "Nicolada", width: 1080, height: 1080 %>
          <% end %>
          <div class="navbar-burger" role="button" aria-label="menu" aria-expanded="false" data-target="navbar-vertical">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </div>
        </div>
        <div class="navbar-menu" id="navbar-vertical">
          <div class="navbar-start"> 
              <%= link_to "Home", "/", class: "navbar-item header__link" %>            
              <%= link_to "Work", "/work", class: "navbar-item header__link" %>     
              <%= link_to "About", "/about", class: "navbar-item header__link" %>          
              <%= link_to "Contact", "/contact", class: "navbar-item header__link" %>
          </div>
          <div class="navbar-end">
            <div class="navbar-item">
              <div class="btn__wrapper">
                <%= link_to "Resume", "https://nicolada-website.s3.us-east-1.amazonaws.com/Nicole_Salazar_Resume.pdf", target: "_blank", rel: "noopener", class: "btn" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="nicolada__wrapper">
      <%= yield %>
    </main>

    <footer class="footer">
      <div class="footer__bouncy-top">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 200" preserveAspectRatio="none">
          <path id="bouncy-path" d="M0,40 Q720,120 1440,40 L1440,160 L0,160 Z"/>
          <path id="bouncy-line" d="M0,40 Q720,120 1440,40" fill="none" stroke="black" stroke-width="2"/>
        </svg>
      </div>
      <div class="container">
        <div class="columns is-multiline">
          <div class="column is-12-tablet is-three-fifths-desktop">
            <div class="footer__header-wrapper">
              <h2 class="footer__header is-hidden-tablet-only">
                Punchy, fun &
                <br>
                a little sweet
              </h2>
              <h2 class="footer__header is-hidden-desktop is-hidden-mobile">
                Punchy, fun & a little sweet
              </h2>
              <p class="footer__cta"> If that sounds like your kind of designer, let's talk.</p>
              <%= link_to "nmsguzman@gmail.com", "mailto:nmsguzman@gmail.com", class: "footer__email" %>
              <%= image_tag asset_path("star-pink.svg"), alt: "Pink Asterisk", class: "footer__pink-asterisk" %>
              <%= image_tag asset_path("star-yellow.svg"), alt: "Yellow Asterisk", class: "footer__yellow-asterisk" %>
            </div>
          </div>
          <div class="column is-12-tablet is-two-fifths-desktop">
            <div class="columns footer__links-wrapper">
              <div class="column is-4-tablet is-narrow-desktop">
                <h3 class="footer__title">Work</h3>
                  <ul>
                      <li>
                        <%= link_to "Product Design", "/ux-ui", class: "footer__link" %>
                      </li>
                      <li>
                        <%= link_to "Graphic Design", "/graphic-design", class: "footer__link" %>
                      </li>
                      <li>
                        <%= link_to "Resume", "https://nicolada-website.s3.us-east-1.amazonaws.com/Nicole_Salazar_Resume.pdf", target: "_blank", rel: "noopener", class: "footer__link" %>
                      </li>
                  </ul>
              </div>
              <div class="column is-4-tablet is-narrow-desktop">
                <h3 class="footer__title">About</h3>
                  <ul>
                    <li>
                      <%= link_to "About", "/about", class: "footer__link" %>
                    </li>
                    <li>
                      <%= link_to "Contact", "/contact", class: "footer__link" %>
                    </li>
                  </ul>
              </div>
              <div class="column is-4-tablet is-narrow-desktop">
                <h3 class="footer__title">Connect</h3>
                  <ul>
                    <li>
                      <%= link_to "Instagram", "https://www.instagram.com/itsnicolada/", class: "footer__link" %>
                    </li>
                    <li>
                      <%= link_to "LinkedIn", "https://www.linkedin.com/in/nicolada", class: "footer__link" %>
                    </li>
                    <li>
                      <%= link_to "GitHub", "https://github.com/nicoleurl", class: "footer__link" %>
                    </li>
                  </ul>
              </div>
            </div>
          </div>
        </div>
        <div class="footer__credits-wrapper">
          <hr>
          <div class="columns">
            <div class="column is-6">
              <p class="footer_copyright">© 2026 Nicolada. All Rights Reserved.</p>
            </div>
            <div class="column is-6">
              <%= link_to image_tag("nicolada_logo.svg", alt: "Nicolada Logo", width: "116"), "/", class: "footer__logo" %>
              <p class="footer_signature"> Website by Nicolada</p>
            </div>
          </div>
        </div>
      </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/Draggable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/Flip.min.js"></script>
    <%= javascript_importmap_tags %>
  </body>
</html>
